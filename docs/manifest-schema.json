{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolnexus.local/schemas/manifest-schema.json",
  "title": "ToolNexus Tool Manifest Contract (Unified Baseline)",
  "description": "Canonical reporting contract that unifies baseline manifest fields used across JS integrity validation and C# loader/runtime normalization.",
  "type": "object",
  "required": [
    "slug",
    "title",
    "category",
    "modulePath",
    "templatePath",
    "styles",
    "runtimeLanguage",
    "executionCapability",
    "uiMode",
    "complexityTier"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string"
    },
    "modulePath": {
      "type": "string",
      "minLength": 1
    },
    "templatePath": {
      "type": "string",
      "minLength": 1
    },
    "styles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "runtimeLanguage": {
      "type": "string",
      "minLength": 1
    },
    "executionCapability": {
      "type": "string",
      "minLength": 1
    },
    "uiMode": {
      "type": "string",
      "enum": [
        "auto",
        "custom"
      ]
    },
    "complexityTier": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4,
        5
      ]
    }
  },
  "additionalProperties": true
}
