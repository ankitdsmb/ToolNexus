@model ToolPageViewModel
@{
    ViewData["Title"] = Model.Seo.Title;
    ViewData["Description"] = Model.Seo.Description;
    ViewData["CanonicalUrl"] = Model.Seo.CanonicalUrl;
    ViewData["JsonLd"] = Model.Seo.JsonLd;
    ViewData["Keywords"] = Model.Seo.Keywords;

    var contextPlugins = ToolNexus.Web.Runtime.ToolContextPlugins.All;

    var contextPluginLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Overview"] = "Overview",
        ["Features"] = "Features",
        ["QuickStart"] = "Quick Start",
        ["Guidance"] = "Guidance",
        ["Examples"] = "Examples",
        ["UseCases"] = "Use Cases",
        ["Faq"] = "FAQ",
        ["RelatedTools"] = "Related Tools"
    };

    var configuration = Context.RequestServices.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>();
    var runtimeLogCaptureEnabled = configuration.GetValue<bool>("LoggingOptions:EnableRuntimeLogCapture", true);
    var runtimeLogEndpoint = runtimeLogCaptureEnabled
        ? configuration["LoggingOptions:RuntimeLogEndpoint"]
        : null;
}

@section Head {
    <link rel="stylesheet" href="~/css/tool-auto-professional.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tool-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tool-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tool-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tool-workspace.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(Model.RuntimeCssPath))
    {
        <link rel="stylesheet" href="@Model.RuntimeCssPath" asp-append-version="true" />
    }
}

<article class="tool-shell-page tool-shell-page--workspace workspace-shell page-shell upgread_tool_shell_page tool-shell-page--execution-first"
         data-upgread="surface"
         data-runtime-priority="execution-first"
         data-runtime-layout="modern"
         aria-label="Tool runtime page">

    @* SSR contract marker *@
    <h1>@Model.Tool.Title</h1>

    <section class="tool-shell-page__workspace workspace-shell__runtime-zone"
             aria-label="Runtime workspace"
             data-workspace-zone="runtime">

        @await Html.PartialAsync("ToolShellPartial", Model)
    </section>

    <aside class="tool-seo tool-shell-page__docs workspace-shell__context-rail tool-article-prose control-recession shell-passive-mode upgread_tool_docs_rail"
           data-upgread="surface"
           data-tool-docs="true"
           data-nosnippet="false"
           data-workspace-zone="context"
           aria-label="Tool documentation"
           data-reference-layer="secondary">

        @foreach (var plugin in contextPlugins)
        {
            var isPrimaryDocSection =
            plugin.Equals("Overview", StringComparison.OrdinalIgnoreCase) ||
            plugin.Equals("QuickStart", StringComparison.OrdinalIgnoreCase);

            <section class="tool-md-section"
                     data-doc-section="@plugin"
                     data-doc-priority="@(isPrimaryDocSection ? "primary" : "secondary")">

                @if (isPrimaryDocSection)
                {
                    <h3>@contextPluginLabels[plugin]</h3>
                    <div class="tool-md-content">
                        @await Html.PartialAsync(ToolNexus.Web.Runtime.ToolContextPlugins.ToPartialPath(plugin), Model)
                    </div>
                }
                else
                {
                    <details class="runtime-doc-disclosure">
                        <summary>@contextPluginLabels[plugin]</summary>
                        <div class="runtime-doc-disclosure__body tool-md-content">
                            @await Html.PartialAsync(ToolNexus.Web.Runtime.ToolContextPlugins.ToPartialPath(plugin), Model)
                        </div>
                    </details>
                }
            </section>
        }
    </aside>
</article>

@section Scripts {
    <script type="application/json" id="toolnexus-config">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
                                                        {
                                                            apiBaseUrl = Model.ApiBaseUrl,
                                                            toolExecutionPathPrefix = Model.ToolExecutionPathPrefix,
                                                            runtimeModulePath = Model.RuntimeModulePath,
                                                            manifestEndpoint = Model.ManifestEndpoint,
                                                            tool = new
                                                            {
                                                                slug = Model.Tool.Slug,
                                                                title = Model.Tool.Title,
                                                                seoDescription = Model.Seo.Description,
                                                                exampleInput = Model.Tool.ExampleInput,
                                                                clientSafeActions = Model.Tool.ClientSafeActions,
                                                                actions = Model.Tool.Actions,
                                                                operationSchema = Model.Tool.OperationSchema
                                                            },
                                                            runtimeUiMode = Model.RuntimeUiMode,
                                                            runtimeComplexityTier = Model.RuntimeComplexityTier,
                                                            runtimeEnvironment = Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Hosting.IWebHostEnvironment>().EnvironmentName,
                                                            runtimeTemplateMountMode = configuration["RuntimeOptions:TemplateMountMode"] ?? "content-host",
                                                            isAdmin = Model.IsAdminPreview,
                                                            runtimeLogEndpoint,
                                                            runtimeRoutes = new
                                                            {
                                                                clientLogEndpoints = new[] { runtimeLogEndpoint }
                                                            }
                                                        }))</script>
    <script type="application/json" id="toolnexus-logging">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
                                                         {
                                                             minimumLevel = configuration["LoggingOptions:RuntimeLogLevel"] ?? configuration["LoggingOptions:MinimumLevel"] ?? "Information",
                                                             runtimeDebugEnabled = configuration.GetValue<bool>("LoggingOptions:RuntimeDebugEnabled"),
                                                             enableRuntimeLogCapture = runtimeLogCaptureEnabled
                                                         }))</script>
    <script type="application/json" id="toolnexus-runtime">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
                                                         {
                                                             correlationId = Context.TraceIdentifier
                                                         }))</script>
    <script type="module" src="~/js/tool-shell-bootstrap.js" asp-append-version="true"></script>
    <script type="module" src="~/js/tool-shell-page.js" asp-append-version="true"></script>
    <script type="module" src="/js/tool-runtime.js"></script>
}
