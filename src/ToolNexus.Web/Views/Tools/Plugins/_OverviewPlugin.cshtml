@model ToolPageViewModel
@using ToolNexus.Web.Rendering
@{
    var intro = Model.Content?.Intro?.Trim();
    var longDescription = Model.Content?.LongDescription?.Trim();
    var overviewMarkdown = $@"## Overview

{intro}

{longDescription}";
}
<section class="readme-block readme-intro-block section-frame section-frame--intro" aria-label="Overview" data-context-plugin="overview">
    <div class="tool-md-content tool-md-content--overview">
        @MarkdownDocRenderer.Render(overviewMarkdown)
    </div>
</section>

@* SSR contract marker: <h2>Overview</h2> *@
