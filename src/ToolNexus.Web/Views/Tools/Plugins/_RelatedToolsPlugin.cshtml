@model ToolPageViewModel
@if (Model.Content?.RelatedTools.Any() == true && Model.RelatedTools.Any())
{
    <details class="readme-disclosure" data-context-plugin="related-tools">
        <summary>Related tools</summary>
        <section class="readme-block section-frame" aria-label="Related tools">
            <p class="tool-section__eyebrow">RelatedToolsGrid</p>
            <h2>Related tools</h2>
            <div class="readme-card-grid readme-card-grid--related">
                @foreach (var relatedTool in Model.RelatedTools)
                {
                    <article class="readme-card" data-actionable-card="true" tabindex="0">
                        <h3>@relatedTool.Title</h3>
                        <a href="/tools/@relatedTool.Slug">@relatedTool.Title</a>
                    </article>
                }
            </div>
        </section>
    </details>
}
