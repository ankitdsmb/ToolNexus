@model ToolPageViewModel
@if (Model.Content?.RelatedTools.Any() == true && Model.RelatedTools.Any())
{
    <section class="readme-block readme-guidance section-frame" aria-label="Workflow guidance" data-context-plugin="guidance">
        <p class="tool-section__eyebrow">ContextualGuidance</p>
        <h2>Next actions</h2>
        <ul class="readme-guidance__list">
            @foreach (var relatedTool in Model.RelatedTools.Take(3))
            {
                <li>
                    <a class="readme-guidance__action" href="/tools/@relatedTool.Slug">
                        <span>@relatedTool.Title</span>
                    </a>
                </li>
            }
        </ul>
    </section>
}
