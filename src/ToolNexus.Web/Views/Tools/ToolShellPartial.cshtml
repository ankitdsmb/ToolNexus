@model ToolPageViewModel
@{
    Layout = null;
}

@* Runtime contract: DO NOT CHANGE anchor attributes *@
<section id="tool-root"
         class="tool-shell-page__runtime upgread_tool_runtime"
         data-upgread="surface"
         data-tool-shell="true"
         data-tool-root="true"
         data-runtime-density="balanced"
         data-tool-slug="@Model.Tool.Slug"
         aria-label="Interactive runtime"
         data-execution-flow="input-action-result-reference">

    <header data-tool-context="true"
            data-tool-header="true"
            class="tn-tool-header"
            aria-label="Tool execution context">
        <span class="tool-context-pill tool-context-pill--authority">
            <span class="tn-skeleton-chip"></span>Authority: Unified Runtime
        </span>
        <span class="tool-context-pill">
            <span class="tn-skeleton-chip"></span>Runtime: Auto Resolve
        </span>
        <span class="tool-context-pill">
            <span class="tn-skeleton-chip"></span>Policy: Conformance Guarded
        </span>
        <span class="tool-context-pill">
            <span class="tn-skeleton-chip"></span>Lifecycle: Ready
        </span>
    </header>

    <div data-tool-status="true"
         data-runtime-status-primary="true"
         class="tool-execution-status runtime-metrics-row tn-runtime-skeleton"
         role="status"
         aria-live="polite">
        <span class="tn-skeleton-chip"></span>
        <span>Ready · Initializing execution intelligence…</span>
    </div>

    <footer data-tool-followup="true"
            data-tool-actions="true"
            class="tool-execution-panel tn-toolbar-skeleton"
            data-command-dock="true"
            aria-label="Follow-up actions">

        <div class="tool-execution-panel__primary-actions"
             aria-label="Primary execution actions">
            <button type="button" disabled class="tool-btn tool-btn--primary">
                <span class="tn-skeleton-chip"></span>Run command
            </button>
        </div>

        <div class="tool-execution-panel__secondary-actions"
             aria-label="Secondary execution actions">
            <button type="button" class="tool-btn tool-btn--ghost" data-tool-fullscreen-toggle="true" aria-pressed="false">
                Expand workspace
            </button>
            <button type="button" disabled class="tool-btn tool-btn--ghost">
                <span class="tn-skeleton-chip"></span>Command dock loading
            </button>
        </div>
    </footer>

    @* FULL WIDTH runtime host — template mounts here *@
    <section data-tool-content-host="true"
             class="tool-runtime-content-host workspace-dominance execution-surface-anchor control-recession shell-passive-mode upgread_tool_content_host"
             data-upgread="surface"
             aria-label="Tool content host"
             data-execution-surface="unified">

        @* Runtime template handoff (SAFE — required by upgraded template flow) *@
        <section data-runtime-template-handoff="true"
                 data-runtime-template-mount-target="content-host"
                 class="tool-runtime-template-handoff"
                 aria-label="Tool runtime template handoff">
        </section>

        @* Canonical extension anchors — DO NOT CHANGE *@
        <section data-tool-input="true"
                 aria-label="Tool input extension slot"
                 class="tn-editor-skeleton"></section>

        <section data-tool-output="true"
                 aria-label="Tool output extension slot"
                 class="tn-editor-skeleton"></section>
    </section>

    <section class="tn-runtime-toast-region"
             aria-live="polite"
             aria-label="Runtime notifications"></section>
</section>
