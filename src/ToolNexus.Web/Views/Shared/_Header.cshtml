@* ToolNexus — Premium Header | Runtime Safe | No JS touched *@
<header class="site-header upgread_header" role="banner">
    <div class="upgread_header__inner">
        <a href="/" class="upgread_brand" aria-label="ToolNexus home">
            <svg class="upgread_brand__mark" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="7" height="7" rx="1.5" fill="currentColor" opacity=".9" />
                <rect x="11" y="2" width="7" height="7" rx="1.5" fill="currentColor" opacity=".55" />
                <rect x="2" y="11" width="7" height="7" rx="1.5" fill="currentColor" opacity=".55" />
                <rect x="11" y="11" width="7" height="7" rx="1.5" fill="currentColor" opacity=".9" />
            </svg>
            <span class="upgread_brand__name">ToolNexus</span>
            <span class="upgread_brand__tag">WORKSPACE</span>
        </a>

        <button class="upgread_cmd" id="cmdPaletteBtn" type="button"
                aria-label="Open command palette (Ctrl+K)" aria-keyshortcuts="Control+K" data-command-palette-trigger>
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5" />
                <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            <span class="upgread_cmd__text">Search tools…</span>
            <kbd class="upgread_cmd__kbd">⌘K</kbd>
        </button>

        <nav class="upgread_header__nav" aria-label="Primary navigation">
            <a href="/tools" class="upgread_nav-link">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                    <rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                    <rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                    <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                </svg>
                <span>Explore Tools</span>
            </a>

            <button id="themeToggle"
                    class="upgread_theme-toggle theme-toggle"
                    type="button"
                    aria-label="Toggle light/dark theme"
                    aria-pressed="false">
                <span class="theme-toggle__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path d="M12 2.5a1 1 0 0 1 1 1v1.15a1 1 0 1 1-2 0V3.5a1 1 0 0 1 1-1Zm0 16.35a1 1 0 0 1 1 1V21a1 1 0 1 1-2 0v-1.15a1 1 0 0 1 1-1Zm9.5-7.35a1 1 0 1 1 0 2h-1.15a1 1 0 1 1 0-2h1.15ZM4.65 12.5a1 1 0 1 1 0 2H3.5a1 1 0 1 1 0-2h1.15Zm13.1 5.35a1 1 0 0 1 1.42 0l.82.82a1 1 0 0 1-1.42 1.42l-.82-.82a1 1 0 0 1 0-1.42Zm-12.32 0a1 1 0 0 1 1.42 1.42l-.82.82a1 1 0 1 1-1.42-1.42l.82-.82Zm13.14-12.32a1 1 0 0 1 1.42 1.42l-.82.82a1 1 0 1 1-1.42-1.42l.82-.82Zm-12.32 0a1 1 0 1 1 1.42 1.42l-.82.82a1 1 0 0 1-1.42-1.42l.82-.82ZM12 7.25a4.75 4.75 0 1 0 0 9.5V7.25Z" />
                    </svg>
                </span>
            </button>
        </nav>

    </div>
</header>
