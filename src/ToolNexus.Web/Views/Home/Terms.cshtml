@{
    ViewData["Title"] = "Terms of Service | ToolNexus";
    ViewData["Description"] = "Read the ToolNexus terms of service in plain language, including responsibilities, data handling expectations, and acceptable use.";
    ViewData["CanonicalUrl"] = $"{Context.Request.Scheme}://{Context.Request.Host}/terms";
    ViewData["Keywords"] = "ToolNexus terms of service, tool usage rules, developer terms";
}

<article class="static-page legal-page page-shell" aria-label="ToolNexus terms of service">
    <header class="static-page__header">
        <h1>Terms of Service</h1>
        <p>This is the practical version of our rules. I built ToolNexus for fast developer workflows, so these terms are here to keep things safe and predictable for everyone.</p>
    </header>

    <nav class="static-page__section static-page__nav" aria-label="Terms quick links">
