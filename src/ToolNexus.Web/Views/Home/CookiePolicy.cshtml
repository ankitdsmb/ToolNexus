@{
    ViewData["Title"] = "Cookie Policy | ToolNexus";
    ViewData["Description"] = "Understand how ToolNexus uses cookies and similar storage in practical terms.";
    ViewData["CanonicalUrl"] = $"{Context.Request.Scheme}://{Context.Request.Host}/cookie-policy";
    ViewData["Keywords"] = "ToolNexus cookie policy, cookie usage, browser storage";
}

<article class="static-page legal-page page-shell" aria-label="ToolNexus cookie policy">
    <header class="static-page__header">
        <h1>Cookie Policy</h1>
        <p>This page explains the small bits of browser storage we use and why. No smoke, no legal maze.</p>
    </header>

    <nav class="static-page__section static-page__nav" aria-label="Cookie policy quick links">
        <h2>Related legal pages</h2>
        <ul class="static-page__link-list">
            <li><a href="/terms">Terms of Service</a></li>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/contact-us">Contact us</a></li>
        </ul>
    </nav>

    <section class="static-page__section">
        <h2>What cookies are used for</h2>
        <p>Cookies and local storage are used for practical things like session continuity, basic preferences, and keeping the site functioning correctly.</p>
    </section>

    <section class="static-page__section">
        <h2>Types we may use</h2>
        <ul>
            <li><strong>Essential cookies:</strong> Needed for core site behavior and security.</li>
            <li><strong>Preference storage:</strong> Saves settings like theme choices when available.</li>
            <li><strong>Analytics signals:</strong> High-level usage metrics to understand performance and reliability.</li>
        </ul>
    </section>

    <section class="static-page__section">
        <h2>What we do not do</h2>
        <p>We do not use cookies to sell your personal data. We do not run creepy cross-site tracking profiles.</p>
    </section>

    <section class="static-page__section">
        <h2>How to manage cookies</h2>
        <p>You can clear or block cookies in your browser settings at any time. Just know that some features may stop working as expected if essential cookies are blocked.</p>
        <p>Example: if a session cookie is blocked, sign-in or security workflows may fail.</p>
    </section>

    <section class="static-page__section">
        <h2>Policy updates</h2>
        <p>If cookie behavior changes in a meaningful way, this page will be updated.</p>
    </section>
</article>
