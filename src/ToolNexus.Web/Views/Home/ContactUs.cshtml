@model ToolNexus.Web.Models.ContactUsViewModel
@{
    ViewData["Title"] = "Contact Us | ToolNexus";
    ViewData["Description"] = "Send a message to the ToolNexus team. We store each request so we can triage and respond from the admin dashboard.";
    ViewData["CanonicalUrl"] = $"{Context.Request.Scheme}://{Context.Request.Host}/contact-us";
    ViewData["Keywords"] = "ToolNexus contact, support, feature request";
}

<article class="static-page contact-page page-shell" aria-label="Contact ToolNexus">
    <header class="static-page__header">
        <h1>Contact Us</h1>
        <p id="contactHelp">I built ToolNexus because I got tired of juggling random one-off converters in ten different tabs. If something breaks in your flow, send it here and I’ll see it in the ops dashboard.</p>
        <p>Good messages usually include one concrete input, what you expected, and what came back instead. That is enough for us to reproduce most bugs quickly.</p>
    </header>

    @if (Model.Submitted)
    {
        <div class="alert alert-success" role="status">
            Message received. It is now stored in our support queue and visible to admins in the dashboard.
        </div>
    }

    <form method="post" class="contact-form contact-form--elite" novalidate aria-describedby="contactHelp">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="field-error mb-3"></div>

        <div class="contact-form__grid contact-form__grid--elite">
            <div class="floating-field">
                <input asp-for="Name" autocomplete="name" placeholder=" " />
                <label asp-for="Name">Name</label>
                <small class="field-error"><span asp-validation-for="Name"></span></small>
            </div>

            <div class="floating-field">
                <input asp-for="Email" autocomplete="email" placeholder=" " />
                <label asp-for="Email">Email</label>
                <small class="field-error"><span asp-validation-for="Email"></span></small>
            </div>

            <div class="floating-field floating-field--full">
                <input asp-for="Subject" placeholder=" " />
                <label asp-for="Subject">Subject</label>
                <small class="field-error"><span asp-validation-for="Subject"></span></small>
            </div>
        </div>

        <div class="floating-field floating-field--textarea">
            <textarea asp-for="Message" rows="8" placeholder=" "></textarea>
            <label asp-for="Message">Message</label>
            <small class="field-error"><span asp-validation-for="Message"></span></small>
        </div>

        <button type="submit" class="tool-btn tool-btn--primary contact-form__submit">Send Message</button>
        <p class="contact-form__security">This now persists to our database (table: <code>contact_messages</code>) so we can actually track and close the loop.</p>
    </form>

    <section class="static-page__section">
        <h2>What this inbox is good for</h2>
        <p>Bug reports, weird edge-case payloads, and requests for new utility tools.</p>
        <p>If you can share a tiny sample JSON/XML/text input, do it. It usually cuts triage time in half.</p>
    </section>
</article>

