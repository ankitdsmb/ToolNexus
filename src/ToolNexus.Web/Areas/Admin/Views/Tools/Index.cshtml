@model ToolNexus.Web.Areas.Admin.Models.ToolAdminIndexViewModel
@{
    ViewData["Title"] = "Tool Workspace";
}

<div class="d-none" data-admin-primary-actions>
    <a class="btn btn-sm btn-primary" href="#tool-editor-form">New Tool</a>
</div>
<div class="d-none" data-admin-bulk-actions>
    <button type="button" class="btn btn-sm btn-success" data-bulk-action="enable">Enable</button>
    <button type="button" class="btn btn-sm btn-warning" data-bulk-action="disable">Disable</button>
</div>
<div class="d-none" data-admin-filters>
    
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h3 class="card-title mb-0">Tools</h3>
                <small class="text-secondary">Shortcuts: Ctrl/Cmd + F focus table filter · Ctrl/Cmd + Shift + E enable selected · Ctrl/Cmd + Shift + D disable selected</small>
            </div>
            <div class="card-body border-bottom py-2">
                <form asp-action="BulkToggleStatus" method="post" id="bulk-status-form" class="d-flex gap-2 align-items-center flex-wrap">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="enabled" id="bulk-enabled-input" value="true" />
                    <input id="tool-filter" class="form-control form-control-sm" placeholder="Filter tools by name/slug" style="max-width: 280px;" />
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="select-visible">Select Visible</button>
                    <button type="button" class="btn btn-sm btn-outline-danger" id="clear-selected">Clear</button>
                    <button type="button" class="btn btn-sm btn-success" data-bulk-action="enable">Enable Selected</button>
                    <button type="button" class="btn btn-sm btn-warning" data-bulk-action="disable">Disable Selected</button>
                    <span id="bulk-selection-count" class="badge bg-azure-lt">0 selected</span>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table" id="tools-table" data-admin-data-table>
                    <thead>
                        <tr><th><input type="checkbox" id="select-all-tools" aria-label="Select all tools" /></th><th data-sortable-key="name">Name</th><th data-sortable-key="slug">Slug</th><th data-sortable-key="category">Category</th><th data-sortable-key="status">Status</th><th data-sortable-key="updated">Updated</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var tool in Model.Tools)
                    {
                        var isEnabled = tool.Status == "Enabled";
                        <tr data-tool-row data-tool-status="@(isEnabled ? "enabled" : "disabled")" data-tool-search="@($"{tool.Name} {tool.Slug}".ToLowerInvariant())" data-name="@tool.Name" data-slug="@tool.Slug" data-category="@tool.Category" data-status="@tool.Status" data-updated="@tool.UpdatedAt.ToString("O")">
                            <td><input type="checkbox" class="tool-select" value="@tool.Id" aria-label="Select @tool.Name" /></td>
                            <td>@tool.Name</td>
                            <td><code>@tool.Slug</code></td>
                            <td>@tool.Category</td>
                            <td><span class="badge @(isEnabled ? "bg-success-lt" : "bg-secondary-lt")">@tool.Status</span></td>
                            <td>@tool.UpdatedAt.ToLocalTime().ToString("u")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@tool.Id">Edit</a>
                                <form asp-action="ToggleStatus" asp-route-id="@tool.Id" method="post" class="d-inline" data-single-toggle-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="enabled" value="@(tool.Status == "Enabled" ? "false" : "true")" />
                                    <button class="btn btn-sm btn-outline-secondary" type="submit">@(tool.Status == "Enabled" ? "Disable" : "Enable")</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><h3 class="card-title">@(Model.Form.Id.HasValue ? "Edit Tool" : "Add Tool")</h3></div>
            <div class="card-body">
                <form asp-action="Save" method="post" id="tool-editor-form">
                            @Html.AntiForgeryToken()
                            <input asp-for="Form.Id" type="hidden" />
                            <input asp-for="Form.VersionToken" type="hidden" />
                            <input asp-for="Form.ExecutionVersionToken" type="hidden" />
                <ul class="nav nav-tabs" id="tool-editor-tabs" role="tablist">
                    <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-definition" type="button">Definition</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-execution" type="button">Execution</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-content" type="button" @(Model.Form.Id.HasValue ? null : "disabled")>Content</button></li>
                </ul>
                @if (Model.Conflict is not null)
                {
                    <partial name="_AdminConcurrencyConflictPanel" model="Model.Conflict" />
                }
                <div class="tab-content pt-3">
                    <div class="tab-pane fade show active" id="tab-definition">
                            <div class="mb-2"><label asp-for="Form.Name"></label><input class="form-control" asp-for="Form.Name" /></div>
                            <div class="mb-2"><label asp-for="Form.Slug"></label><input class="form-control" asp-for="Form.Slug" /></div>
                            <div class="mb-2"><label asp-for="Form.Description"></label><textarea class="form-control" asp-for="Form.Description"></textarea></div>
                            <div class="mb-2"><label asp-for="Form.Category"></label><input class="form-control" asp-for="Form.Category" /></div>
                            <div class="mb-2"><label asp-for="Form.Status"></label><select class="form-select" asp-for="Form.Status"><option>Enabled</option><option>Disabled</option></select></div>
                            <div class="mb-2"><label asp-for="Form.Icon"></label><input class="form-control" asp-for="Form.Icon" /></div>
                            <div class="mb-2"><label asp-for="Form.SortOrder"></label><input class="form-control" asp-for="Form.SortOrder" /></div>
                            <div class="mb-2"><label asp-for="Form.InputSchema"></label><textarea class="form-control" asp-for="Form.InputSchema" rows="4"></textarea></div>
                            <div class="mb-2"><label asp-for="Form.OutputSchema"></label><textarea class="form-control" asp-for="Form.OutputSchema" rows="4"></textarea></div>
                    </div>
                    <div class="tab-pane fade" id="tab-execution">
                            <div class="mb-2"><label asp-for="Form.ExecutionMode"></label><select class="form-select" asp-for="Form.ExecutionMode"><option>Local</option><option>Remote</option><option>Sandbox</option><option>Disabled</option></select></div>
                            <div class="mb-2"><label asp-for="Form.TimeoutSeconds"></label><input class="form-control" asp-for="Form.TimeoutSeconds" /></div>
                            <div class="mb-2"><label asp-for="Form.MaxRequestsPerMinute"></label><input class="form-control" asp-for="Form.MaxRequestsPerMinute" /></div>
                            <div class="mb-2"><label asp-for="Form.MaxInputSize"></label><input class="form-control" asp-for="Form.MaxInputSize" /></div>
                            <div class="form-check mb-2"><input class="form-check-input" asp-for="Form.IsExecutionEnabled" /><label class="form-check-label" asp-for="Form.IsExecutionEnabled"></label></div>
                    </div>
<div class="tab-pane fade" id="tab-content" data-tool-id="@Model.Form.Id">
                        <div id="content-editor-status" class="small text-muted mb-2">Open content tab to load.</div>
                        <div id="content-conflict-panel-host"></div>
                        <div id="content-editor-root"></div>
                        <button id="save-content-btn" class="btn btn-primary btn-sm mt-2" type="button">Save Content</button>
                    </div>
                </div>
                            <div asp-validation-summary="All" class="text-danger mt-2"></div>
                            <button class="btn btn-primary mt-2" type="submit">Save Tool</button>
                        </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script type="module" src="~/js/admin/tools-index.js" asp-append-version="true"></script>
}
