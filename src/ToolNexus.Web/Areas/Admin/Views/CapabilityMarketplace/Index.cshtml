@{
    ViewData["Title"] = "Capability Marketplace";
}

<h2>Capability Marketplace Registry</h2>

<div class="row g-2 mb-3">
    <div class="col-md-4">
        <label class="form-label" for="tool-filter">Tool</label>
        <input class="form-control" id="tool-filter" placeholder="tool id" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="status-filter">Status</label>
        <select class="form-select" id="status-filter">
            <option value="">All</option>
            <option value="0">Installed</option>
            <option value="1">Disabled</option>
            <option value="2">Deprecated</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label" for="synced-after">Synced after</label>
        <input class="form-control" id="synced-after" type="date" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button id="apply-filters" class="btn btn-primary w-100" type="button">Apply filters</button>
    </div>
</div>

<p class="text-secondary" id="marketplace-last-synced"></p>

<table class="table table-sm" id="marketplace-table">
    <thead>
    <tr>
        <th>Capability</th>
        <th>Tool</th>
        <th>Status</th>
        <th>Authority</th>
        <th>Runtime</th>
        <th>Snapshot</th>
    </tr>
    </thead>
    <tbody></tbody>
</table>

@section Scripts {
<script type="module" src="~/js/admin/capabilitymarketplace-index.js" asp-append-version="true"></script>
}
