@{
    ViewData["Title"] = "Operator Command Center";
}

<section class="admin-ops-page" data-admin-ops-page>
    <div class="admin-ops-header">
        <div>
            <h2 class="mb-1">Operator Command Center</h2>
            <p class="text-secondary mb-0">Runtime operations, governance visibility, and actionable telemetry in one workspace.</p>
        </div>
        <button class="btn btn-primary" id="refresh-monitoring" type="button">Refresh workspace</button>
    </div>

    <div class="alert d-none" id="ops-feedback" role="status" aria-live="polite"></div>

    <div class="row g-3 mb-3" id="global-runtime-status">
        <div class="col-sm-6 col-xl-3"><article class="card admin-ops-metric"><div class="card-body"><small>Environment</small><div id="env-status">production</div></div></article></div>
        <div class="col-sm-6 col-xl-3"><article class="card admin-ops-metric"><div class="card-body"><small>Health</small><div id="pending-count">-</div></div></article></div>
        <div class="col-sm-6 col-xl-3"><article class="card admin-ops-metric"><div class="card-body"><small>Alerts</small><div id="dead-letter-count">-</div></div></article></div>
        <div class="col-sm-6 col-xl-3"><article class="card admin-ops-metric"><div class="card-body"><small>Queue</small><div id="retry-count">-</div></div></article></div>
    </div>

    <div class="card admin-ops-card" id="stream-panel"><div class="card-body">
        <h4 class="card-title">Live Execution Stream</h4>
        <div class="table-responsive"><table class="table table-sm table-hover align-middle"><thead><tr><th>When</th><th>Tool</th><th>Authority</th><th>Adapter</th><th>Runtime</th><th>Governance</th><th>Duration</th><th>Status</th></tr></thead><tbody id="stream-body"></tbody></table></div>
    </div></div>

    <div class="card admin-ops-card" id="controls-panel"><div class="card-body">
        <h4 class="card-title">Operator Action Zone</h4>
        <p class="text-secondary">All commands require operator reason, explicit confirmation, and audit emission.</p>
        <div class="admin-ops-actions" role="group" aria-label="Operator action commands">
            <button class="btn btn-outline-warning" data-command="cache-reset" data-risk="medium" type="button">Reset Cache</button>
            <button class="btn btn-outline-warning" data-command="queue-drain" data-risk="high" type="button">Drain Queue</button>
            <button class="btn btn-outline-warning" data-command="queue-replay" data-risk="medium" type="button">Reprocess Failed Jobs</button>
        </div>
    </div></div>

    <div class="card admin-ops-card" id="autonomy-panel"><div class="card-body">
        <h4 class="card-title">Autonomous Insights</h4>
        <small class="text-secondary">AI-generated recommendations. Execution requires explicit operator approval.</small>
        <div class="table-responsive mt-2"><table class="table table-sm table-hover align-middle"><thead><tr><th>Action</th><th>Risk</th><th>Confidence</th><th>Impact</th><th>Controls</th></tr></thead><tbody id="autonomy-body"></tbody></table></div>
    </div></div>

    <div class="row g-3 mb-3" id="domain-grid">
        <div class="col-lg-4"><div class="card admin-ops-card"><div class="card-body"><h5>Governance</h5><div id="governance-summary">-</div></div></div></div>
        <div class="col-lg-4"><div class="card admin-ops-card"><div class="card-body"><h5>Capability Lifecycle</h5><div id="capability-summary">-</div><a href="/admin/capabilities/marketplace" class="btn btn-outline-secondary btn-sm mt-2">Open Editor</a></div></div></div>
        <div class="col-lg-4"><div class="card admin-ops-card"><div class="card-body"><h5>Quality Intelligence</h5><div id="quality-summary">-</div></div></div></div>
    </div>

    <div class="card admin-ops-card" id="platform-optimization"><div class="card-body">
        <h4 class="card-title">Platform Optimization</h4>
        <div class="table-responsive"><table class="table table-sm table-hover align-middle"><thead><tr><th>Domain</th><th>Recommendation</th><th>Confidence</th><th>Simulation</th><th>Actions</th></tr></thead><tbody id="optimization-body"></tbody></table></div>
    </div></div>

    <div class="card admin-ops-card" id="incidents-panel"><div class="card-body">
        <h4 class="card-title">Incident + Diagnostics</h4>
        <div class="table-responsive"><table class="table table-sm table-hover align-middle"><thead><tr><th>Last Occurrence (UTC)</th><th>Severity/Type</th><th>Tool</th><th>Error Message</th><th class="text-end">Count</th></tr></thead><tbody id="incidents-body"></tbody></table></div>
    </div></div>
</section>

<script type="module" src="~/js/admin/executionmonitoring-index.js" asp-append-version="true"></script>
