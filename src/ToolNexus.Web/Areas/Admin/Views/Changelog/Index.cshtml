@model IReadOnlyList<ToolNexus.Infrastructure.Content.Entities.ChangelogEntryEntity>
@using ToolNexus.Web.Areas.Admin.Models
@{
    ViewData["Title"] = "Changelog";
    var form = ViewBag.Form as ChangelogEntryFormModel ?? new ChangelogEntryFormModel();
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">@(form.Id.HasValue ? "Edit entry" : "Create entry")</h3>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Changelog" asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@form.Id" />

                    <div class="mb-3">
                        <label class="form-label" for="Version">Version</label>
                        <input class="form-control" id="Version" name="Version" value="@form.Version" placeholder="v1.6.0" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Title">Title</label>
                        <input class="form-control" id="Title" name="Title" value="@form.Title" placeholder="Smoother runtime boot + smaller bundles" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Description">Description</label>
                        <textarea class="form-control" id="Description" name="Description" rows="4" placeholder="What changed and why it matters to a developer in the flow state.">@form.Description</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Tag">Tag</label>
                        <select class="form-select" id="Tag" name="Tag">
                            @foreach (var option in new[] { "Added", "Improved", "Fixed", "Removed" })
                            {
                                if (string.Equals(form.Tag, option, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option selected="selected" value="@option">@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="ReleaseDate">Release date</label>
                        <input class="form-control" id="ReleaseDate" name="ReleaseDate" type="date" value="@form.ReleaseDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit">Save entry</button>
                        @if (form.Id.HasValue)
                        {
                            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Changelog" asp-action="Index">Cancel edit</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Published entries</h3>
            </div>
            <div class="list-group list-group-flush">
                @if (!Model.Any())
                {
                    <div class="list-group-item">
                        No entries yet. Add one on the left and it will show up on <code>/changelog</code>.
                    </div>
                }
                else
                {
                    @foreach (var entry in Model)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="text-secondary small">@entry.Version · @entry.ReleaseDate.ToString("MMM dd, yyyy") · @entry.Tag</div>
                                    <h4 class="mb-1">@entry.Title</h4>
                                    <p class="text-secondary mb-0">@entry.Description</p>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Changelog" asp-action="Edit" asp-route-id="@entry.Id">Edit</a>
                                    <form asp-area="Admin" asp-controller="Changelog" asp-action="Delete" asp-route-id="@entry.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
